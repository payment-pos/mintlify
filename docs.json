              "sanal-pos/webhooks/signature",
              "sanal-pos/webhooks/retry-policy"
            ]
          },
          {
            "group": "Backoffice",
            "pages": [
              "sanal-pos/backoffice/connectors",
              "sanal-pos/backoffice/configurations",
              "sanal-pos/backoffice/settlements",
              "sanal-pos/backoffice/chargebacks"
            ]
