{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Payven Developer Portal",
  "description": "Türkiye'nin finansal teknoloji altyapısı. Tek API ile sanal POS, para transferi, fraud, mutabakat, fatura ödeme.",
  "colors": {
    "primary": "#1A56DB",
    "light": "#3B6FE8",
    "dark": "#0F2A6B"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://docs.payven.com.tr"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "fonts": {
    "heading": { "family": "Inter", "weight": 600 },
    "body": { "family": "Inter" }
  },
  "navbar": {
    "links": [
      { "label": "Konsol", "href": "https://dashboard.payven.com.tr" },
      { "label": "Durum", "href": "/resources/status" },
      { "label": "Changelog", "href": "/resources/changelog" }
    ],
    "primary": {
      "type": "button",
      "label": "Konsola Git",
      "href": "https://dashboard.payven.com.tr"
    }
  },
  "footer": {
    "socials": {
      "linkedin": "https://www.linkedin.com/company/payven"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Başlarken",
        "groups": [
          {
            "group": "Tanışın",
            "pages": [
              "index",
              "documentation/quickstart",
              "documentation/architecture",
              "documentation/account-model"
            ]
          },
          {
            "group": "Temel Kavramlar",
            "pages": [
              "documentation/concepts/authentication",
              "documentation/concepts/response-format",
              "documentation/concepts/amounts",
              "documentation/concepts/idempotency",
              "documentation/concepts/errors",
              "documentation/concepts/rate-limiting",
              "documentation/concepts/ip-whitelist",
              "documentation/concepts/versioning",
              "documentation/concepts/webhooks",
              "documentation/concepts/timestamps"
            ]
          },
          {
            "group": "Güvenlik",
            "pages": [
              "documentation/security/pci-dss",
              "documentation/security/api-key-best-practices",
              "documentation/security/go-live-checklist"
            ]
          }
        ]
      },
      {
        "tab": "Sanal POS",
        "groups": [
