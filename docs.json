            ]
          },
          {
            "group": "Webhook'lar",
            "pages": [
              "para-transferi/webhooks/overview",
              "para-transferi/webhooks/events"
            ]
          },
          {
            "group": "Hata Kodları",
            "pages": ["para-transferi/errors/overview"]
          }
        ]
      },
      {
        "tab": "Identity & Auth",
        "groups": [
          {
            "group": "Genel Bakış",
            "pages": ["identity/overview"]
          },
          {
            "group": "Oturum Bilgisi",
            "pages": [
              "identity/auth/me",
