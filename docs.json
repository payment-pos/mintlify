              "sanal-pos/test/test-cards",
              "sanal-pos/test/postman"
            ]
          },
          {
            "group": "API Referansı",
            "openapi": {
              "source": "/api-reference/sanal-pos/openapi.json",
              "directory": "api-reference/sanal-pos"
            }
          },
          {
            "group": "Hata Kodları",
            "pages": [
              "sanal-pos/errors/overview",
              "sanal-pos/errors/payven-codes",
              "sanal-pos/errors/bank-codes"
            ]
          }
        ]
      },
      {
        "tab": "Para Transferi",
        "groups": [
          {
            "group": "Yakında",
            "pages": ["resources/coming-soon"]
          }
        ]
      },
      {
        "tab": "Fraud",
        "groups": [
