{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Payven Developer Portal",
  "description": "Türkiye'nin lisanslı ödeme kuruluşları, bankaları ve fintek platformları için ödeme altyapısı dokümantasyonu.",
  "colors": {
    "primary": "#1A56DB",
    "light": "#3B6FE8",
    "dark": "#0F2A6B"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://docs.payven.com.tr"
  },
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 600
    },
    "body": {
      "family": "Inter"
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://dashboard.payven.com.tr"
      },
      {
        "label": "Durum",
        "href": "https://status.payven.com.tr"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Konsola Git",
      "href": "https://dashboard.payven.com.tr"
    }
  },
  "footer": {
    "socials": {
      "linkedin": "https://www.linkedin.com/company/payven"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Dokümantasyon",
        "groups": [
          {
            "group": "Başlarken",
            "pages": [
              "documentation/index",
              "documentation/quickstart",
              "documentation/architecture",
              "documentation/account-model"
            ]
          },
          {
            "group": "Temel Kavramlar",
            "pages": [
              "documentation/concepts/authentication",
              "documentation/concepts/response-format",
              "documentation/concepts/amounts",
              "documentation/concepts/idempotency",
              "documentation/concepts/errors",
              "documentation/concepts/rate-limiting",
              "documentation/concepts/ip-whitelist",
              "documentation/concepts/versioning",
              "documentation/concepts/webhooks",
              "documentation/concepts/timestamps"
            ]
          },
          {
            "group": "Güvenlik",
            "pages": [
              "documentation/security/pci-dss",
              "documentation/security/api-key-best-practices",
              "documentation/security/go-live-checklist"
            ]
          }
        ]
      },
      {
        "tab": "Identity & Auth",
        "groups": [
          {
            "group": "Genel Bakış",
            "pages": [
              "identity/overview"
            ]
          },
          {
            "group": "Kimlik Doğrulama",
            "pages": [
              "identity/auth/login",
              "identity/auth/refresh",
              "identity/auth/logout",
              "identity/auth/register",
              "identity/auth/me",
              "identity/auth/plan"
            ]
          },
          {
            "group": "API Anahtarı Yönetimi",
            "pages": [
              "identity/api-keys/overview",
              "identity/api-keys/create",
              "identity/api-keys/rotate",
              "identity/api-keys/revoke"
            ]
          },
          {
            "group": "Lookup Servisleri",
            "pages": [
              "identity/lookups/banks",
              "identity/lookups/bins",
              "identity/lookups/mcc-codes",
              "identity/lookups/cities-districts"
            ]
          },
          {
            "group": "Doğrulama",
            "pages": [
              "identity/validation/card",
              "identity/validation/iban"
            ]
          },
          {
            "group": "API Referansı",
            "openapi": {
              "source": "/api-reference/identity/openapi.json",
              "directory": "api-reference/identity"
            }
          }
        ]
      },
      {
